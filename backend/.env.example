# ============================================================
# asian.directory Backend Environment Variables
# ============================================================
# Copy this file to .env for local development.
# On Railway, set these as service variables.
# ============================================================

# Server
PORT=3000
NODE_ENV=production

# JWT Secret (REQUIRED — generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# CSRF Secret
CSRF_SECRET=change-me-to-another-random-string

# ============================================================
# Database
# ============================================================
# Railway PostgreSQL: automatically set by the Railway PostgreSQL plugin.
# When DATABASE_URL is set, the server uses PostgreSQL.
# When DATABASE_URL is NOT set, it falls back to local SQLite.
DATABASE_URL=postgresql://user:password@host:5432/railway

# ============================================================
# CORS
# ============================================================
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=https://asian.directory,https://www.asian.directory,https://asiandirectory-production-7ec4.up.railway.app

# ============================================================
# OAuth (optional — leave blank to disable)
# ============================================================
# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://asiandirectory-production-7ec4.up.railway.app/api/auth/google/callback

# Facebook Login
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://asiandirectory-production-7ec4.up.railway.app/api/auth/facebook/callback
