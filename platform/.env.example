# =============================================================================
# SEA Directory Platform — environment. Copy to .env.local; NEVER commit real values.
# The app FAILS CLOSED: if a required var is missing/invalid it refuses to boot
# (lib/env.ts). There are NO hardcoded secret fallbacks — this is deliberate.
# =============================================================================

NODE_ENV=development

# --- Database (Railway Postgres; image MUST include pgvector + PGroonga) ---
DATABASE_URL=postgresql://user:password@host:5432/railway
# off = no TLS (Railway private network) | require = TLS w/ cert verify | insecure = TLS no verify (avoid)
DATABASE_SSL=off

# --- Better Auth (generate: openssl rand -hex 32) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Embeddings: self-hosted BGE-M3 inference endpoint returning 1024-dim vectors ---
EMBEDDINGS_URL=http://localhost:8080
EMBEDDINGS_API_KEY=

# --- LLM (ADR-003): Claude/Gemini primary, SEA-LION fallback ---
LLM_PRIMARY=anthropic            # anthropic | google
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# SEA-LION (OpenAI-compatible). Prefer a self-hosted endpoint; the free hosted API is 10 req/min, no SLA.
SEALION_BASE_URL=
SEALION_API_KEY=
